<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set appBrand = 'Scrapy Vacancies Function App' %}
    <title>{% block title %}Vacancies{% endblock %} | {{ appBrand }}</title>
    <style>
        :root {
            --bg: #f7f9fc;
            --surface: #ffffff;
            --ink: #0f172a;
            --muted: #475569;
            --line: #dbe3ef;
            --brand: #0b5fff;
            --brand-ink: #ffffff;
            --radius: 12px;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            color: var(--ink);
            background: linear-gradient(180deg, #edf3ff 0%, var(--bg) 180px, var(--bg) 100%);
        }

        .wrap {
            width: min(980px, 92vw);
            margin: 0 auto;
        }

        header {
            padding: 24px 0 12px;
        }

        .site-title {
            margin: 0;
            font-size: clamp(1.3rem, 2vw, 1.7rem);
        }

        .site-title a {
            color: var(--ink);
            text-decoration: none;
        }

        main {
            padding: 10px 0 42px;
        }

        .panel {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            padding: 18px;
            box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04);
        }

        .muted { color: var(--muted); }

        .btn {
            display: inline-block;
            padding: 0.6rem 0.95rem;
            border-radius: 10px;
            border: 1px solid transparent;
            text-decoration: none;
            font-weight: 600;
        }

        .btn-primary {
            background: var(--brand);
            color: var(--brand-ink);
        }

        .btn-secondary {
            border-color: var(--line);
            color: var(--ink);
            background: #fff;
        }

        .field-grid {
            display: grid;
            gap: 12px;
            grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
            margin-bottom: 12px;
        }

        label {
            font-size: 0.9rem;
            font-weight: 600;
            display: block;
            margin-bottom: 5px;
        }

        input[type="text"],
        select {
            width: 100%;
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 0.55rem 0.62rem;
            font: inherit;
        }

        .cards {
            display: grid;
            gap: 12px;
            margin-top: 16px;
        }

        .card {
            border: 1px solid var(--line);
            border-radius: 10px;
            padding: 14px;
            background: #fff;
        }

        .card h2 {
            margin: 0 0 8px;
            font-size: 1.05rem;
        }

        .meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 0 0 10px;
            padding: 0;
            list-style: none;
        }

        .meta li {
            font-size: 0.9rem;
            color: var(--muted);
            background: #f8fbff;
            border: 1px solid #d9e7ff;
            border-radius: 999px;
            padding: 0.25rem 0.55rem;
        }

        .pagination {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 18px;
            gap: 10px;
            flex-wrap: wrap;
        }

        .detail h1 { margin-top: 0; margin-bottom: 8px; }

        .detail dl {
            display: grid;
            grid-template-columns: 160px 1fr;
            gap: 6px 12px;
        }

        .detail dt {
            font-weight: 700;
            color: var(--muted);
        }

        .detail dd {
            margin: 0;
        }

        @media (max-width: 640px) {
            .detail dl {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
<header>
    <div class="wrap">
        <p class="site-title"><a href="{{ siteUrl('') }}">{{ appBrand }}</a></p>
    </div>
</header>
<main>
    <div class="wrap">
        {% block content %}{% endblock %}
    </div>
</main>
</body>
</html>
