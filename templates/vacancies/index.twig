{% extends "_layouts/site" %}

{% set pageTitle = 'Current vacancies' %}
{% set q = (craft.app.request.getQueryParam('q') ?? '')|trim %}
{% set qSafe = q|replace({'"': ' '}) %}
{% set location = (craft.app.request.getQueryParam('location') ?? '')|trim %}
{% set contractType = (craft.app.request.getQueryParam('contractType') ?? '')|trim %}

{% set contractOptions = {
    '': 'Any contract type',
    'full_time': 'Full-time',
    'part_time': 'Part-time',
    'temporary': 'Temporary',
    'permanent': 'Permanent',
    'casual': 'Casual',
    'apprenticeship': 'Apprenticeship',
    'unknown': 'Unknown',
} %}

{% set vacanciesQuery = craft.entries()
    .section('importedVacancies')
    .status('live')
    .approvalStatus('approved')
    .orderBy('closingDate ASC, title ASC')
    .limit(10)
%}

{% if q %}
    {% set searchExpression = 'title:"' ~ qSafe ~ '" OR organisation:"' ~ qSafe ~ '" OR location:"' ~ qSafe ~ '"' %}
    {% set vacanciesQuery = vacanciesQuery.search(searchExpression) %}
{% endif %}

{% if location %}
    {% set vacanciesQuery = vacanciesQuery.location(location) %}
{% endif %}

{% if contractType %}
    {% set vacanciesQuery = vacanciesQuery.contractType(contractType) %}
{% endif %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block content %}
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-10px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .panel {
            animation: fadeIn 0.5s ease-out;
        }

        .page-header {
            margin-bottom: 32px;
            padding-bottom: 24px;
            border-bottom: 2px solid transparent;
            border-image: linear-gradient(90deg, #667eea, #764ba2, transparent) 1;
        }

        .page-header h1 {
            margin: 0 0 8px 0;
            font-size: clamp(1.75rem, 3vw, 2.25rem);
            font-weight: 800;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .page-header p {
            margin: 0;
            font-size: 1.05rem;
            color: #64748b;
        }

        .filter-form {
            background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
            border: 1px solid rgba(102, 126, 234, 0.2);
            border-radius: 16px;
            padding: 28px;
            margin-bottom: 32px;
            box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
        }

        .filter-form .field-grid {
            margin-bottom: 20px;
        }

        .filter-form label {
            font-weight: 600;
            color: #334155;
            font-size: 0.95rem;
        }

        .filter-form input[type="text"],
        .filter-form select {
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 1rem;
            transition: all 0.2s ease;
            background: #fff;
        }

        .filter-form input[type="text"]:focus,
        .filter-form select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .filter-form input[type="text"]::placeholder {
            color: #94a3b8;
        }

        .btn-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn {
            transition: all 0.2s ease;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

        .cards {
            display: grid;
            gap: 20px;
            margin-top: 24px;
        }

        .card {
            background: #fff;
            border: 1px solid rgba(148, 163, 184, 0.2);
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            animation: slideIn 0.4s ease-out;
            animation-fill-mode: both;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.1);
            border-color: rgba(102, 126, 234, 0.3);
        }

        .card:hover::before {
            transform: scaleX(1);
        }

        .card h2 {
            margin: 0 0 14px 0;
            font-size: 1.25rem;
            font-weight: 700;
            line-height: 1.4;
        }

        .card h2 a {
            color: #0f172a;
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .card h2 a:hover {
            color: #667eea;
        }

        .meta {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin: 0 0 18px;
            padding: 0;
            list-style: none;
        }

        .meta li {
            font-size: 0.875rem;
            font-weight: 500;
            color: #475569;
            background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
            border: 1px solid rgba(148, 163, 184, 0.3);
            border-radius: 8px;
            padding: 6px 14px;
            transition: all 0.2s ease;
        }

        .meta li:nth-child(1) {
            background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
            border-color: #fbbf24;
            color: #92400e;
        }

        .meta li:nth-child(2) {
            background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
            border-color: #60a5fa;
            color: #1e40af;
        }

        .card-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .card .btn {
            font-size: 0.95rem;
            padding: 10px 18px;
        }

        .pagination {
            background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
            border: 1px solid rgba(102, 126, 234, 0.2);
            border-radius: 12px;
            padding: 20px;
            margin-top: 32px;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.04);
        }

        .pagination p {
            font-weight: 600;
            color: #475569;
        }

        .no-results {
            text-align: center;
            padding: 48px 24px;
            background: linear-gradient(135deg, #f8f9ff 0%, #fff 100%);
            border: 2px dashed rgba(102, 126, 234, 0.3);
            border-radius: 16px;
            margin-top: 24px;
        }

        .no-results p {
            font-size: 1.1rem;
            color: #64748b;
            margin: 0;
        }

        /* Stagger animation for cards */
        .card:nth-child(1) { animation-delay: 0.05s; }
        .card:nth-child(2) { animation-delay: 0.1s; }
        .card:nth-child(3) { animation-delay: 0.15s; }
        .card:nth-child(4) { animation-delay: 0.2s; }
        .card:nth-child(5) { animation-delay: 0.25s; }
        .card:nth-child(6) { animation-delay: 0.3s; }
        .card:nth-child(7) { animation-delay: 0.35s; }
        .card:nth-child(8) { animation-delay: 0.4s; }
        .card:nth-child(9) { animation-delay: 0.45s; }
        .card:nth-child(10) { animation-delay: 0.5s; }
    </style>

    <section class="panel">
        <div class="page-header">
            <h1>{{ pageTitle }}</h1>
            <p>Browse current opportunities. New vacancies are reviewed before publication.</p>
        </div>

        <form class="filter-form" method="get" action="{{ siteUrl('vacancies') }}">
            <div class="field-grid">
                <div>
                    <label for="q">🔍 Keyword</label>
                    <input id="q" name="q" type="text" value="{{ q|e }}" placeholder="e.g. planner, admin, Cardiff">
                </div>
                <div>
                    <label for="location">📍 Location</label>
                    <input id="location" name="location" type="text" value="{{ location|e }}" placeholder="Exact location">
                </div>
                <div>
                    <label for="contractType">💼 Contract type</label>
                    <select id="contractType" name="contractType">
                        {% for value, label in contractOptions %}
                            <option value="{{ value|e }}"{% if value == contractType %} selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="btn-group">
                <button class="btn btn-primary" type="submit">Apply Filters</button>
                <a class="btn btn-secondary" href="{{ siteUrl('vacancies') }}">Reset</a>
            </div>
        </form>

        {% paginate vacanciesQuery as pageInfo, vacancies %}

        {% if vacancies|length %}
            <div class="cards">
                {% for vacancy in vacancies %}
                    {% set contract = vacancy.contractType ?? null %}
                    {% set detailUrl = vacancy.url ?: null %}
                    {% set originalUrl = (vacancy.sourceUrl and vacancy.sourceUrl.url) ? vacancy.sourceUrl.url : ((vacancy.applyUrl and vacancy.applyUrl.url) ? vacancy.applyUrl.url : null) %}
                    {% set displayTitle = vacancy.title ?: 'Vacancy' %}
                    <article class="card">
                        <h2>
                            {% if detailUrl %}
                                <a href="{{ detailUrl }}">{{ displayTitle|e }}</a>
                            {% elseif originalUrl %}
                                <a href="{{ originalUrl }}" target="_blank" rel="noopener noreferrer">{{ displayTitle|e }}</a>
                            {% else %}
                                {{ displayTitle|e }}
                            {% endif %}
                        </h2>
                        <ul class="meta">
                            <li>🏢 {{ vacancy.organisation|e }}</li>
                            <li>📍 {{ vacancy.location|e }}</li>
                            {% if vacancy.salary %}<li>💰 {{ vacancy.salary|e }}</li>{% endif %}
                            {% if contract and contract.value %}<li>💼 {{ contract.label|e }}</li>{% endif %}
                            {% if vacancy.closingDate %}<li>⏰ Closes {{ vacancy.closingDate|date('d M Y') }}</li>{% endif %}
                        </ul>
                        <div class="card-actions">
                            {% if detailUrl %}
                                <a class="btn btn-primary" href="{{ detailUrl }}">View Details</a>
                            {% endif %}
                            {% if originalUrl %}
                                <a class="btn btn-secondary" href="{{ originalUrl }}" target="_blank" rel="noopener noreferrer">Direct Apply Link →</a>
                            {% endif %}
                            {% if not detailUrl and not originalUrl %}
                                <p class="muted">Link unavailable for this record.</p>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>

            <nav class="pagination" aria-label="Pagination">
                <div>
                    {% if pageInfo.prevUrl %}
                        <a class="btn btn-secondary" href="{{ pageInfo.prevUrl }}">← Previous</a>
                    {% endif %}
                </div>
                <p>Page {{ pageInfo.currentPage }} of {{ pageInfo.totalPages }}</p>
                <div>
                    {% if pageInfo.nextUrl %}
                        <a class="btn btn-secondary" href="{{ pageInfo.nextUrl }}">Next →</a>
                    {% endif %}
                </div>
            </nav>
        {% else %}
            <div class="no-results">
                {% if q or location or contractType %}
                    <p>🔍 No approved vacancies match your filters. Try adjusting your search criteria.</p>
                {% else %}
                    <p>📋 No vacancies are published yet. Please check back shortly.</p>
                {% endif %}
            </div>
        {% endif %}
    </section>
{% endblock %}
