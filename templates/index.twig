{% extends "_layouts/site" %}

{% set approvedVacanciesCount = craft.entries()
    .section('importedVacancies')
    .status('live')
    .approvalStatus('approved')
    .count()
%}

{% set closingSoonCount = craft.entries()
    .section('importedVacancies')
    .status('live')
    .approvalStatus('approved')
    .closingDate(['and', '>= ' ~ now|date('Y-m-d'), '<= ' ~ now|date_modify('+14 days')|date('Y-m-d')])
    .count()
%}

{% block title %}Home{% endblock %}

{% block content %}
    <style>
        .hero {
            padding: 22px;
            border-radius: 14px;
            background: linear-gradient(130deg, #0b5fff 0%, #1f78ff 55%, #5ca5ff 100%);
            color: #fff;
            margin-bottom: 16px;
        }

        .hero h1 {
            margin-top: 0;
            margin-bottom: 10px;
            font-size: clamp(1.5rem, 2.8vw, 2rem);
        }

        .hero p {
            margin-top: 0;
            margin-bottom: 14px;
            max-width: 62ch;
            line-height: 1.5;
        }

        .hero .btn-primary {
            background: #fff;
            color: #0b5fff;
            border-color: #fff;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        .tile {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 12px;
            padding: 14px;
        }

        .tile h2 {
            margin: 0;
            font-size: 0.95rem;
            color: #475569;
            font-weight: 700;
        }

        .tile strong {
            display: block;
            margin-top: 6px;
            font-size: 1.6rem;
            line-height: 1.1;
            color: #0f172a;
        }

        .links {
            background: #fff;
            border: 1px solid #dbe3ef;
            border-radius: 12px;
            padding: 16px;
        }

        .links h2 {
            margin-top: 0;
            margin-bottom: 8px;
        }

        .links ul {
            margin: 0;
            padding-left: 18px;
            line-height: 1.6;
        }
    </style>

    <section class="hero">
        <h1>Welcome to the vacancies portal</h1>
        <p>
            Find current approved opportunities, review closing dates, and open each vacancy for full details and application links.
        </p>
        <a class="btn btn-primary" href="{{ siteUrl('vacancies') }}">Browse vacancies</a>
    </section>

    <section class="grid" aria-label="Vacancy overview">
        <article class="tile">
            <h2>Approved live vacancies</h2>
            <strong>{{ approvedVacanciesCount }}</strong>
        </article>
        <article class="tile">
            <h2>Closing in next 14 days</h2>
            <strong>{{ closingSoonCount }}</strong>
        </article>
        <article class="tile">
            <h2>Last updated</h2>
            <strong>{{ now|date('d F Y') }}</strong>
        </article>
    </section>

    <section class="links">
        <h2>Quick links</h2>
        <ul>
            <li><a href="{{ siteUrl('vacancies') }}">View all current vacancies</a></li>
            <li><a href="{{ cpUrl('entries/importedVacancies') }}">Admin: review imported vacancies</a></li>
        </ul>
    </section>
{% endblock %}
